# HireFlow AI - Environment Configuration
# MySQL Database Configuration

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=hireflow-dev-secret-key-2024
DEBUG=True

# Database Configuration (Local MySQL)
DATABASE_URL=mysql+pymysql://root:Rutik%40123@localhost:3306/hireflow_ai
SQLALCHEMY_TRACK_MODIFICATIONS=False

# JWT Configuration
JWT_SECRET_KEY=hireflow-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=86400

# Mail Configuration (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Google Gemini AI Configuration
GEMINI_API_KEY=

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=static/uploads

# Application URLs
FRONTEND_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000

# Rate Limiting
RATELIMIT_ENABLED=False
